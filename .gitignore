# Runtime cache (generated, not source)
data/cache/media_hash_cache.json
data/cache/**/*.html

# Generated ML artifacts (train to regenerate; never commit)
models/*.pkl
data/artifacts/*.pkl

# Stock event images (re-downloadable; inflate repo size)
data/event_images/*.jpg
data/event_images/*.jpeg
data/event_images/*.png
data/event_images/*.webp

# Timestamped intermediate training snapshots (retain only golden labeled dataset)
data/processed/canonical_labeled_training_*.csv
data/raw/perdido_events_backup*.csv
data/raw/perdido_events_sept*.csv

# Pipeline logs (generated at runtime)
regenerate_descriptions/*.log
scripts.pipeline.regenerate_descriptions/*.log
output/analytics/

# Ignore ad-hoc debug scripts (contain creds; do not commit)
check_*.py
!scripts/dev/check_evcal_srow.py
compare_events.py
fix_eventon_metadata.py

# Secrets (local env for automation; do not commit)
scripts/windows/env.ps1

