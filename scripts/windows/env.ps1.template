# Environment Configuration Template for Windows
#
# INSTRUCTIONS:
# 1. Copy this file to scripts/windows/env.ps1 (local machine only)
# 2. Edit it with your actual WordPress and email credentials
# 3. For security, you can also store at ~/.secrets/envision_env.ps1
#
# DO NOT COMMIT THIS FILE TO GIT!
# It is listed in .gitignore to prevent accidental credential exposure.

# WordPress Configuration
$env:WP_SITE_URL = "https://your-wordpress-site.org"
$env:WP_USERNAME = "your_wp_username"
$env:WP_APP_PASSWORD = "xxxx xxxx xxxx xxxx xxxx xxxx"

# Email / SMTP Configuration
$env:SMTP_SERVER = "smtp.gmail.com"
$env:SMTP_PORT = "587"
$env:SENDER_EMAIL = "your-email@gmail.com"
$env:EMAIL_PASSWORD = "your_gmail_app_password_16_chars"
$env:RECIPIENT_EMAIL = "notification-email@gmail.com"

# OpenAI Configuration (OPTIONAL - only for description enhancement)
# Get your API key from: https://platform.openai.com/api-keys
# WARNING: Keep this secret - treat it like a password!
$env:OPENAI_API_KEY = "sk-proj-your-api-key"
$env:OPENAI_MODEL = "gpt-4o-mini"
$env:OPENAI_USE_BATCH = "false"
$env:OPENAI_DRY_RUN = "false"
$env:OPENAI_TOP_N = "100"
$env:OPENAI_MIN_CONFIDENCE = "0.75"

# Behavior & Timezone
$env:AUTO_UPLOAD = "false"
$env:SITE_TIMEZONE = "America/Chicago"
