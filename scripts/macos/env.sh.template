#!/bin/bash
# Environment Configuration Template for macOS/Linux
#
# INSTRUCTIONS:
# 1. Copy this file to scripts/macos/env.sh (local machine only)
# 2. Edit it with your actual WordPress and email credentials
# 3. For security, you can also store at ~/.secrets/envision_env.sh
#
# DO NOT COMMIT THIS FILE TO GIT!
# It is listed in .gitignore to prevent accidental credential exposure.

# WordPress Configuration
export WP_SITE_URL="https://your-wordpress-site.org"
export WP_USERNAME="your_wp_username"
export WP_APP_PASSWORD="xxxx xxxx xxxx xxxx xxxx xxxx"

# Email / SMTP Configuration
export SMTP_SERVER="smtp.gmail.com"
export SMTP_PORT="587"
export SENDER_EMAIL="your-email@gmail.com"
export EMAIL_PASSWORD="your_gmail_app_password_16_chars"
export RECIPIENT_EMAIL="notification-email@gmail.com"

# Behavior & Timezone
export AUTO_UPLOAD="false"
export SITE_TIMEZONE="America/Chicago"
