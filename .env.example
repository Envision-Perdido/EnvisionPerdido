# EnvisionPerdido Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ============================================================================
# SECURITY WARNING: SENSITIVE CREDENTIALS
# ============================================================================
# This file contains placeholders for sensitive information:
# - API Keys (OpenAI, WordPress App Passwords, Email Passwords)
# - Never commit your .env file to GitHub
# - Never share these values in chat, issues, or pull requests
# - If you accidentally expose a key: REVOKE IT IMMEDIATELY
# - Rotate keys regularly (weekly for highly sensitive keys)
# ============================================================================

# WordPress Configuration
# Get these from your WordPress site admin
WP_SITE_URL="https://your-site.example.com"
WP_USERNAME="your_wp_username"
WP_APP_PASSWORD="xxxx xxxx xxxx xxxx xxxx xxxx"

# Email / SMTP Configuration
# For Gmail, generate an App Password: https://support.google.com/accounts/answer/185833
SMTP_SERVER="smtp.gmail.com"
SMTP_PORT="587"
SENDER_EMAIL="your_email@gmail.com"
EMAIL_PASSWORD="your_16_char_app_password"
RECIPIENT_EMAIL="supervisor@example.com"

# Behavior Flags
# AUTO_UPLOAD: Set to 'false' for dry-run (creates drafts, doesn't publish)
# Set to 'true' only after testing thoroughly
AUTO_UPLOAD="false"

# Timezone for EventON epoch calculations
# Common values: America/Chicago, America/New_York, UTC, etc.
SITE_TIMEZONE="America/Chicago"

# OpenAI Configuration (optional - only needed for description enhancement)
# Get your API key from: https://platform.openai.com/api-keys
# SECURITY: Treat this key like a password. Rotate regularly.
# If exposed: https://platform.openai.com/account/api-keys (delete & recreate)
OPENAI_API_KEY="sk-proj-..."
OPENAI_MODEL="gpt-4o-mini"
OPENAI_DRY_RUN="false"

# OpenAI Batch API settings (for cost reduction and async processing)
# Use batch API for cheaper processing (50% cost reduction, slower)
# Set to "true" to use async batch API, "false" for sync API (immediate results)
OPENAI_USE_BATCH="false"

# Only enhance top-N confidence events to reduce API costs
# Set to the number of high-confidence events to enhance (e.g., 50, 100, 200)
OPENAI_TOP_N="100"

# Minimum confidence threshold for description enhancement
# Only events with confidence >= this value will be enhanced (0.0 to 1.0)
OPENAI_MIN_CONFIDENCE="0.75"

# ============================================================================
# KEY ROTATION CHECKLIST
# ============================================================================
# If you accidentally expose any credentials:
# 1. [ ] OpenAI: https://platform.openai.com/api-keys (delete & create new)
# 2. [ ] WordPress: Generate new App Password in Settings > Users
# 3. [ ] Gmail: Remove App Password in Google Account > Security > App Passwords
# 4. [ ] Update .env locally and verify no commits contain old keys
# 5. [ ] Run: git log -S "oldkey" --all (verify not in history)
