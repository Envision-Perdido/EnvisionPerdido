{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://playperdido.local/contracts/play_perdido_event_submission_contract.schema.json",
  "title": "Play Perdido Event Submission Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "source_system",
    "events"
  ],
  "properties": {
    "contract_version": {
      "const": "1.0.0"
    },
    "source_system": {
      "$ref": "#/$defs/sourceSystem"
    },
    "locations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/location"
      },
      "default": []
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/event"
      }
    }
  },
  "$defs": {
    "sourceSystem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "environment",
        "exported_at"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "environment": {
          "type": "string",
          "enum": [
            "production",
            "staging",
            "development",
            "test"
          ]
        },
        "exported_at": {
          "type": "string",
          "format": "date-time"
        },
        "base_url": {
          "type": "string",
          "format": "uri"
        },
        "operator": {
          "type": "string"
        }
      }
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "external_id",
        "name",
        "address_line_1",
        "city",
        "region",
        "postal_code",
        "country_code",
        "venue_type"
      ],
      "properties": {
        "external_id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "address_line_1": {
          "type": "string",
          "minLength": 1
        },
        "address_line_2": {
          "type": "string"
        },
        "city": {
          "type": "string",
          "minLength": 1
        },
        "region": {
          "type": "string",
          "minLength": 1
        },
        "postal_code": {
          "type": "string",
          "minLength": 1
        },
        "country_code": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "venue_type": {
          "type": "string",
          "enum": [
            "bar",
            "restaurant",
            "beach",
            "marina",
            "park",
            "trailhead",
            "market",
            "event-space",
            "music-venue",
            "resort",
            "museum",
            "education",
            "golf-course",
            "community-space",
            "outdoor-site",
            "other"
          ]
        },
        "perdido_fit": {
          "$ref": "#/$defs/perdidoFit"
        },
        "latitude": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "longitude": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "website_url": {
          "type": "string",
          "format": "uri"
        },
        "phone": {
          "type": "string"
        },
        "service_area": {
          "type": "string"
        }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "external_id",
        "title",
        "summary",
        "body",
        "start_at",
        "end_at",
        "timezone",
        "status",
        "location_external_id",
        "categories",
        "perdido_fit"
      ],
      "properties": {
        "external_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 3,
          "maxLength": 140
        },
        "summary": {
          "type": "string",
          "minLength": 20,
          "maxLength": 320
        },
        "body": {
          "type": "string",
          "minLength": 40,
          "maxLength": 12000
        },
        "body_format": {
          "type": "string",
          "enum": [
            "plain_text",
            "limited_html",
            "markdown"
          ],
          "default": "plain_text"
        },
        "start_at": {
          "type": "string",
          "format": "date-time"
        },
        "end_at": {
          "type": "string",
          "format": "date-time"
        },
        "timezone": {
          "type": "string",
          "minLength": 3
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "review",
            "publish",
            "cancelled"
          ]
        },
        "location_external_id": {
          "type": "string",
          "minLength": 1
        },
        "categories": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/category"
          }
        },
        "audience_tags": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/audienceTag"
          }
        },
        "discovery_tags": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/discoveryTag"
          }
        },
        "perdido_fit": {
          "$ref": "#/$defs/perdidoFit"
        },
        "is_free": {
          "type": "boolean"
        },
        "cost": {
          "type": "string",
          "maxLength": 80
        },
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "featured_image": {
          "$ref": "#/$defs/featuredImage"
        },
        "cta": {
          "$ref": "#/$defs/cta"
        },
        "organizer": {
          "$ref": "#/$defs/organizer"
        },
        "review_notes": {
          "type": "string",
          "maxLength": 2000
        },
        "quality_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "confidence_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "suggested_featured": {
          "type": "boolean"
        },
        "raw_source_categories": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "raw_source_location_text": {
          "type": "string"
        }
      }
    },
    "featuredImage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_url"
      ],
      "properties": {
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "alt_text": {
          "type": "string",
          "maxLength": 200
        },
        "copyright_notice": {
          "type": "string",
          "maxLength": 300
        }
      }
    },
    "cta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "url"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 2,
          "maxLength": 40
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "target": {
          "type": "string",
          "enum": [
            "self",
            "blank"
          ],
          "default": "blank"
        }
      }
    },
    "organizer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "phone": {
          "type": "string"
        },
        "website_url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "perdidoFit": {
      "type": "string",
      "enum": [
        "core",
        "adjacent",
        "supporting",
        "out_of_area"
      ]
    },
    "category": {
      "type": "string",
      "enum": [
        "Live Music",
        "Family Friendly",
        "Food & Drink",
        "Markets & Makers",
        "Community",
        "Arts & Culture",
        "Beach & Water",
        "Nature & Outdoors",
        "Free",
        "Classes & Workshops",
        "Nightlife",
        "Seasonal"
      ]
    },
    "audienceTag": {
      "type": "string",
      "enum": [
        "Kid-friendly",
        "Pet friendly",
        "Date night",
        "Low-cost",
        "Outdoor",
        "On the water",
        "Recurring",
        "Local favorite",
        "Educational",
        "Volunteer",
        "Food available",
        "Rainy day"
      ]
    },
    "discoveryTag": {
      "type": "string",
      "enum": [
        "today",
        "tonight",
        "this-weekend",
        "live-music",
        "family",
        "free",
        "food-drink",
        "on-the-water",
        "markets",
        "nature",
        "nightlife"
      ]
    }
  }
}
