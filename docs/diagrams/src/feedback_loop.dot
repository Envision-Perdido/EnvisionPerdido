digraph feedback_loop {
    graph [rankdir=LR, bgcolor="white", pad=0.3, nodesep=0.5, ranksep=0.7, fontname="Helvetica"];
    node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=11, color="#34495E", penwidth=1.2, margin="0.16,0.12"];
    edge [color="#5D6D7E", penwidth=1.3, arrowsize=0.8, fontname="Helvetica", fontsize=10];

    OUT [label="output/pipeline\ncalendar_upload_*.csv", shape=cylinder, fillcolor="#82E0AA", color="#28B463"];
    REVIEW [label="Manual Review\nlabel corrections", fillcolor="#D6DBDF", color="#566573"];
    LABELED [label="data/labeled\ntraining data", shape=cylinder, fillcolor="#82E0AA", color="#28B463"];
    RETRAIN [label="auto_label_and_train.py\nretrain model", fillcolor="#AF7AC5", fontcolor="white", color="#8E44AD"];
    ART [label="data/artifacts\nupdated model", shape=cylinder, fillcolor="#82E0AA", color="#28B463"];
    PIPE [label="Next Pipeline Run", fillcolor="#F8C471", color="#D68910"];

    OUT -> REVIEW -> LABELED -> RETRAIN -> ART -> PIPE -> OUT;
}