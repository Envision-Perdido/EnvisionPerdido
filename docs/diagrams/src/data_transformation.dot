digraph data_transformation {
    graph [rankdir=TB, bgcolor="white", pad=0.45, nodesep=0.65, ranksep=0.95, fontname="Helvetica"];
    node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=12.5, color="#34495E", penwidth=1.3, margin="0.24,0.18"];
    edge [color="#5D6D7E", penwidth=1.5, arrowsize=0.9, fontname="Helvetica", fontsize=11];

    RAW [label="Raw Event\ntitle, description, location, start, url", fillcolor="#D6DBDF", color="#566573"];
    FE [label="Feature Engineering\nbuild_features()\ntitle + description + location + category", fillcolor="#F8C471", color="#D68910"];
    TF [label="TF-IDF Vectorization\nngram_range=(1,2)\nmin_df=2, max_df=0.9\nstrip_accents, sublinear_tf", fillcolor="#D2B4DE", color="#8E44AD"];
    MAT [label="Sparse Feature Matrix\nshape: (N, about 1000)\ncsr_matrix, density about 1-2%", fillcolor="#D6DBDF", color="#566573"];
    SVM [label="LinearSVC\nclass_weight=balanced\nmax_iter=1000\nprediction 0/1 and decision score", fillcolor="#D2B4DE", color="#8E44AD"];
    CONF [label="Confidence Score\nsigmoid(decision_function)\n0.9 sure, 0.5 neutral, 0.1 unsure", fillcolor="#D2B4DE", color="#8E44AD"];
    ENR [label="Enriched Event\nis_community\nconfidence\nneeds_review < 0.75\ntags, venue, image_url", fillcolor="#82E0AA", color="#28B463"];

    RAW -> FE -> TF -> MAT -> SVM -> CONF -> ENR;
}