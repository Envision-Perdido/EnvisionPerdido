digraph script_dependencies {
    graph [rankdir=LR, bgcolor="white", pad=0.45, nodesep=0.7, ranksep=1.0, fontname="Helvetica"];
    node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=12, color="#34495E", penwidth=1.2, margin="0.2,0.14"];
    edge [color="#5D6D7E", penwidth=1.4, arrowsize=0.9, fontname="Helvetica", fontsize=10.5];

    SOURCES [label="Community calendars\nweb pages and ICS feeds", fillcolor="#5DADE2", fontcolor="white", color="#2E86C1"];
    SCRAPERS [label="scripts/scrapers\nperdido_chamber_scraper\nwren_haven_scraper\nmulti_calendar_scraper", fillcolor="#58D68D", fontcolor="white", color="#28B463"];
    RAW [label="data/raw\nraw event exports", shape=cylinder, fillcolor="#82E0AA", color="#28B463"];
    LABELED [label="data/labeled\nreviewed training data", shape=cylinder, fillcolor="#82E0AA", color="#28B463"];
    ML [label="scripts/ml\nsvm_train_from_file\nauto_label_and_train\nsvm_tag_events", fillcolor="#AF7AC5", fontcolor="white", color="#8E44AD"];
    ART [label="data/artifacts\nmodel.pkl\nvectorizer.pkl", shape=cylinder, fillcolor="#82E0AA", color="#28B463"];
    PIPE [label="scripts/pipeline\nautomated_pipeline\nhealth_check", fillcolor="#F8C471", color="#D68910"];
    TOOL [label="scripts/tooling\nenv_loader\nlogger\nevent_normalizer\nvenue_registry\ntag_taxonomy", fillcolor="#AAB7B8", fontcolor="white", color="#7B8A8B"];
    OUT [label="output/pipeline\nCSV, email summaries, logs", shape=cylinder, fillcolor="#82E0AA", color="#28B463"];
    WP [label="wordpress_uploader\nWordPress drafts and metadata", fillcolor="#EC7063", fontcolor="white", color="#C0392B"];
    CACHE [label="data/cache", shape=cylinder, fillcolor="#82E0AA", color="#28B463"];

    SOURCES -> SCRAPERS;
    SCRAPERS -> RAW;
    RAW -> PIPE [label="runtime input"];
    RAW -> LABELED [label="review subset"];
    LABELED -> ML [label="train / retrain"];
    ML -> ART;
    ART -> PIPE [label="inference artifacts"];
    TOOL -> PIPE [dir=both, label="shared helpers"];
    PIPE -> OUT;
    PIPE -> WP;
    WP -> CACHE;
}